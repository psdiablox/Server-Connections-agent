# =============================================================================
# TRACE — Trading Analytics Terminal
# Copy to .env on the server. NEVER commit .env.
# =============================================================================

# --- Inherited from global ---
# DOMAIN and TZ are sourced from /opt/server/.env via the deploy script.
# data.${DOMAIN} is the host this stack serves on.

# --- Postgres / TimescaleDB ---
POSTGRES_USER=trace
POSTGRES_DB=trace
# REQUIRED — long random string. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- App-level auth (single admin user, on top of admin-ip middleware) ---
# Username for the login screen.
TRACE_USER=admin
# bcrypt hash of the password.
# Generate with:  python3 -c "import bcrypt,getpass; print(bcrypt.hashpw(getpass.getpass().encode(),bcrypt.gensalt(rounds=12)).decode())"
TRACE_PASSWORD_HASH=
# Secret for signing the session JWT. Generate with: openssl rand -hex 48
TRACE_JWT_SECRET=

# --- Logging ---
API_LOG_LEVEL=info
COLLECTOR_LOG_LEVEL=info
