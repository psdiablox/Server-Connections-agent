# =============================================================================
# Global Server Environment Variables
# Copy to .env and fill in real values. NEVER commit .env
# =============================================================================

# Primary domain for all services
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate registration
ACME_EMAIL=admin@yourdomain.com

# Timezone (used by all containers)
TZ=Europe/Madrid

# Server IP (used for IP whitelist in admin services)
SERVER_IP=YOUR_SERVER_IP

# Your home/VPN IP (allowed to access admin interfaces)
ADMIN_IP=YOUR_ADMIN_IP

# Docker Hub credentials (optional, avoids pull rate limits)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# Notification webhook (optional, e.g. Discord/Slack for alerts)
ALERT_WEBHOOK_URL=
